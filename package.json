{
  "name": "slap-mac-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run i18n:compile",
    "dev": "next dev",
    "prebuild": "npm run i18n:compile",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
