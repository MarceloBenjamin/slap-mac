  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.16.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.0"
  }
}
